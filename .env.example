# PostgreSQL: Neon, Supabase, Vercel Postgres, свой сервер — всё подходит.
#
# Supabase: не копируйте «как получится» из UI — символы # * @ в пароле ломают URL.
# Соберите строки так (project-ref = ref проекта в дашборде, region = eu-west-1 и т.д.):
#   npm run supabase:urls -- <project-ref> "<пароль_из_Database_settings>" [region]
#
# В Vercel задайте обе переменные:
#   DATABASE_URL — pooler :6543 + ?pgbouncer=true (вывод скрипта)
#   DIRECT_URL — db.<ref>.supabase.co :5432 (вывод скрипта)
DATABASE_URL=""
DIRECT_URL=""

# Пароль входа в /admin (смените в проде)
ADMIN_PASSWORD="admin"

# PostgreSQL: Neon, Supabase, Vercel Postgres, свой сервер — всё подходит.
#
# Достаточно ОДНОЙ переменной DATABASE_URL (как в типичном Next + Prisma проекте).
# Строку с корректно закодированным паролем удобно получить так:
#   npm run supabase:urls -- <project-ref> "<пароль>" [region]
#
# Supabase: в пароле символы # @ * : и т.д. в URL должны быть в виде %23 %40 %2A %3A —
# иначе подключение ломается (в т.ч. «обрезание» пароля после #).
#
# Рекомендация для Vercel (меньше ошибок MaxClients): в DATABASE_URL используйте из вывода
# скрипта строку Transaction pooler :6543 с pgbouncer (блок «VERCEL runtime»).
#
DATABASE_URL=""

# Одноразово: копирование данных локальная БД → прод (npm run db:copy-to-prod)
# LOCAL_DATABASE_URL="postgresql://..."
# DATABASE_URL_PROD="postgresql://..."
# Засеять прод: DATABASE_URL_PROD="..." npm run db:seed:remote
#
# Миграции на прод не идут в сборке Vercel — см. README («Деплой»).
# GitHub Actions → «Migrate database», или локально: DATABASE_URL="..." npm run db:migrate:deploy
#
# Если с Mac seed не доходит до Supabase — GitHub Actions → «Seed database».
# Секрет PRODUCTION_DATABASE_URL = тот же DATABASE_URL, что в Vercel.

# Пароль входа в /admin (смените в проде)
ADMIN_PASSWORD="admin"

# PostgreSQL: Neon, Supabase, Vercel Postgres, свой сервер — всё подходит.
#
# Supabase + Vercel: если прямой db.<ref>.supabase.co даёт P1001 на сборке,
# в DATABASE_URL используйте Session pooler (скрипт ниже). Пароль с # * @ — только через encode.
#
#   npm run supabase:urls -- <project-ref> "<пароль>" [region]
#
DATABASE_URL=""

# Одноразово: копирование данных локальная БД → прод (npm run db:copy-to-prod)
# Supabase: при P1001 на direct — Session pooler из UI или IPv4 add-on (см. скрипт)
# LOCAL_DATABASE_URL="postgresql://..."
# DATABASE_URL_PROD="postgresql://..."
# Засеять прод без правки .env: DATABASE_URL_PROD="..." npm run db:seed:remote
#
# Если с Mac seed не доходит до Supabase — засейте через GitHub Actions:
#   Repo → Settings → Secrets and variables → Actions → New repository secret
#   Name: PRODUCTION_DATABASE_URL
#   Value: тот же DATABASE_URL, что в Vercel (Session pooler).
#   Actions → «Seed database» → Run workflow

# Пароль входа в /admin (смените в проде)
ADMIN_PASSWORD="admin"

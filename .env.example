# PostgreSQL: Neon, Supabase, Vercel Postgres, свой сервер — всё подходит.
#
# Supabase (Vercel): одна переменная DATABASE_URL — прямое подключение db.<ref>.supabase.co:5432
# (не pooler :6543 — migrate deploy на сборке с pooler часто падает).
# Пароль с # * @ закодируйте: npm run supabase:urls -- <project-ref> "<пароль>"
DATABASE_URL=""

# Пароль входа в /admin (смените в проде)
ADMIN_PASSWORD="admin"
